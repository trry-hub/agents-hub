{
  "name": "agents-hub",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.1.0",
  "publisher": "agents-hub",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:agentsHub.sidebar",
    "onCommand:agentsHub.openPanel",
    "onCommand:agentsHub.reloadWindow",
    "onCommand:agentsHub.stopAll",
    "onCommand:agentsHub.explainSelection",
    "onCommand:agentsHub.reviewFile",
    "onCommand:agentsHub.generateTests",
    "onCommand:agentsHub.refactorSelection",
    "onCommand:agentsHub.switchProvider.claude",
    "onCommand:agentsHub.switchProviderActive.claude",
    "onCommand:agentsHub.switchProvider.gemini",
    "onCommand:agentsHub.switchProviderActive.gemini",
    "onCommand:agentsHub.switchProvider.codex",
    "onCommand:agentsHub.switchProviderActive.codex",
    "onCommand:agentsHub.switchProvider.opencode",
    "onCommand:agentsHub.switchProviderActive.opencode",
    "onCommand:agentsHub.switchProvider.goose",
    "onCommand:agentsHub.switchProviderActive.goose",
    "onCommand:agentsHub.switchProvider.aider",
    "onCommand:agentsHub.switchProviderActive.aider"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentsHub",
          "title": "%viewContainer.title%",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agentsHub": [
        {
          "id": "agentsHub.sidebar",
          "name": "%view.sidebar.name%",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "agentsHub.openPanel",
        "title": "%command.openPanel.title%"
      },
      {
        "command": "agentsHub.reloadWindow",
        "title": "%command.reloadWindow.title%"
      },
      {
        "command": "agentsHub.stopAll",
        "title": "%command.stopAll.title%"
      },
      {
        "command": "agentsHub.explainSelection",
        "title": "%command.explainSelection.title%"
      },
      {
        "command": "agentsHub.reviewFile",
        "title": "%command.reviewFile.title%"
      },
      {
        "command": "agentsHub.generateTests",
        "title": "%command.generateTests.title%"
      },
      {
        "command": "agentsHub.refactorSelection",
        "title": "%command.refactorSelection.title%"
      },
      {
        "command": "agentsHub.switchProvider.claude",
        "title": "%command.switchProvider.claude.title%",
        "icon": {
          "light": "media/provider-icons/claude.svg",
          "dark": "media/provider-icons/claude.svg"
        }
      },
      {
        "command": "agentsHub.switchProviderActive.claude",
        "title": "%command.switchProvider.claude.title%",
        "icon": {
          "light": "media/provider-icons/claude.svg",
          "dark": "media/provider-icons/claude.svg"
        }
      },
      {
        "command": "agentsHub.switchProvider.gemini",
        "title": "%command.switchProvider.gemini.title%",
        "icon": {
          "light": "media/provider-icons/gemini.png",
          "dark": "media/provider-icons/gemini.png"
        }
      },
      {
        "command": "agentsHub.switchProviderActive.gemini",
        "title": "%command.switchProvider.gemini.title%",
        "icon": {
          "light": "media/provider-icons/gemini.png",
          "dark": "media/provider-icons/gemini.png"
        }
      },
      {
        "command": "agentsHub.switchProvider.codex",
        "title": "%command.switchProvider.codex.title%",
        "icon": {
          "light": "media/provider-icons/codex.png",
          "dark": "media/provider-icons/codex.png"
        }
      },
      {
        "command": "agentsHub.switchProviderActive.codex",
        "title": "%command.switchProvider.codex.title%",
        "icon": {
          "light": "media/provider-icons/codex.png",
          "dark": "media/provider-icons/codex.png"
        }
      },
      {
        "command": "agentsHub.switchProvider.opencode",
        "title": "%command.switchProvider.opencode.title%",
        "icon": {
          "light": "media/provider-icons/opencode.png",
          "dark": "media/provider-icons/opencode.png"
        }
      },
      {
        "command": "agentsHub.switchProviderActive.opencode",
        "title": "%command.switchProvider.opencode.title%",
        "icon": {
          "light": "media/provider-icons/opencode.png",
          "dark": "media/provider-icons/opencode.png"
        }
      },
      {
        "command": "agentsHub.switchProvider.goose",
        "title": "%command.switchProvider.goose.title%",
        "icon": {
          "light": "media/provider-icons/goose-light.png",
          "dark": "media/provider-icons/goose-dark.png"
        }
      },
      {
        "command": "agentsHub.switchProviderActive.goose",
        "title": "%command.switchProvider.goose.title%",
        "icon": {
          "light": "media/provider-icons/goose-light.png",
          "dark": "media/provider-icons/goose-dark.png"
        }
      },
      {
        "command": "agentsHub.switchProvider.aider",
        "title": "%command.switchProvider.aider.title%",
        "icon": {
          "light": "media/provider-icons/aider.png",
          "dark": "media/provider-icons/aider.png"
        }
      },
      {
        "command": "agentsHub.switchProviderActive.aider",
        "title": "%command.switchProvider.aider.title%",
        "icon": {
          "light": "media/provider-icons/aider.png",
          "dark": "media/provider-icons/aider.png"
        }
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentsHub.switchProvider.claude",
          "when": "view == agentsHub.sidebar && agentsHub.activeProvider != claude",
          "group": "navigation@1"
        },
        {
          "command": "agentsHub.switchProviderActive.claude",
          "when": "view == agentsHub.sidebar && agentsHub.activeProvider == claude",
          "group": "navigation@1"
        },
        {
          "command": "agentsHub.switchProvider.gemini",
          "when": "view == agentsHub.sidebar && agentsHub.activeProvider != gemini",
          "group": "navigation@2"
        },
        {
          "command": "agentsHub.switchProviderActive.gemini",
          "when": "view == agentsHub.sidebar && agentsHub.activeProvider == gemini",
          "group": "navigation@2"
        },
        {
          "command": "agentsHub.switchProvider.codex",
          "when": "view == agentsHub.sidebar && agentsHub.activeProvider != codex",
          "group": "navigation@3"
        },
        {
          "command": "agentsHub.switchProviderActive.codex",
          "when": "view == agentsHub.sidebar && agentsHub.activeProvider == codex",
          "group": "navigation@3"
        },
        {
          "command": "agentsHub.switchProvider.opencode",
          "when": "view == agentsHub.sidebar && agentsHub.activeProvider != opencode",
          "group": "navigation@4"
        },
        {
          "command": "agentsHub.switchProviderActive.opencode",
          "when": "view == agentsHub.sidebar && agentsHub.activeProvider == opencode",
          "group": "navigation@4"
        },
        {
          "command": "agentsHub.switchProvider.goose",
          "when": "view == agentsHub.sidebar && agentsHub.activeProvider != goose",
          "group": "navigation@5"
        },
        {
          "command": "agentsHub.switchProviderActive.goose",
          "when": "view == agentsHub.sidebar && agentsHub.activeProvider == goose",
          "group": "navigation@5"
        },
        {
          "command": "agentsHub.switchProvider.aider",
          "when": "view == agentsHub.sidebar && agentsHub.activeProvider != aider",
          "group": "navigation@6"
        },
        {
          "command": "agentsHub.switchProviderActive.aider",
          "when": "view == agentsHub.sidebar && agentsHub.activeProvider == aider",
          "group": "navigation@6"
        }
      ],
      "commandPalette": [
        {
          "command": "agentsHub.switchProviderActive.claude",
          "when": "false"
        },
        {
          "command": "agentsHub.switchProviderActive.gemini",
          "when": "false"
        },
        {
          "command": "agentsHub.switchProviderActive.codex",
          "when": "false"
        },
        {
          "command": "agentsHub.switchProviderActive.opencode",
          "when": "false"
        },
        {
          "command": "agentsHub.switchProviderActive.goose",
          "when": "false"
        },
        {
          "command": "agentsHub.switchProviderActive.aider",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "command": "agentsHub.explainSelection",
          "when": "editorHasSelection",
          "group": "navigation@10"
        },
        {
          "command": "agentsHub.refactorSelection",
          "when": "editorHasSelection",
          "group": "navigation@11"
        },
        {
          "command": "agentsHub.reviewFile",
          "group": "navigation@12"
        },
        {
          "command": "agentsHub.generateTests",
          "group": "navigation@13"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "agentsHub.defaultProvider": {
          "type": "string",
          "default": "opencode",
          "enum": [
            "claude",
            "gemini",
            "codex",
            "opencode",
            "goose",
            "aider"
          ],
          "description": "%config.defaultProvider.description%"
        },
        "agentsHub.context.includeWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "%config.includeWorkspace.description%"
        },
        "agentsHub.context.includeCurrentFile": {
          "type": "boolean",
          "default": true,
          "description": "%config.includeCurrentFile.description%"
        },
        "agentsHub.context.includeSelection": {
          "type": "boolean",
          "default": true,
          "description": "%config.includeSelection.description%"
        },
        "agentsHub.context.includeDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "%config.includeDiagnostics.description%"
        },
        "agentsHub.context.maxFileChars": {
          "type": "number",
          "default": 12000,
          "minimum": 1000,
          "description": "%config.maxFileChars.description%"
        },
        "agentsHub.context.maxSelectionChars": {
          "type": "number",
          "default": 8000,
          "minimum": 1000,
          "description": "%config.maxSelectionChars.description%"
        },
        "agentsHub.context.maxDiagnostics": {
          "type": "number",
          "default": 12,
          "minimum": 0,
          "description": "%config.maxDiagnostics.description%"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "build:test": "tsc -p tsconfig.json --outDir .test-dist --rootDir src --module commonjs",
    "test": "npm run build:test && node --test tests/*.test.mjs",
    "watch": "node esbuild.mjs --watch",
    "compile": "npm run build",
    "package": "npm run build && npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "js-tiktoken": "^1.0.21"
  }
}
