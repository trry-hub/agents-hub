{
  "name": "agents-hub",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.1.0",
  "publisher": "agents-hub",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:agentsHub.sidebar",
    "onCommand:agentsHub.openPanel",
    "onCommand:agentsHub.reloadWindow",
    "onCommand:agentsHub.refreshProviders",
    "onCommand:agentsHub.openProviderSettings",
    "onCommand:agentsHub.stopAll",
    "onCommand:agentsHub.explainSelection",
    "onCommand:agentsHub.reviewFile",
    "onCommand:agentsHub.generateTests",
    "onCommand:agentsHub.refactorSelection"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentsHub",
          "title": "%viewContainer.title%",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agentsHub": [
        {
          "id": "agentsHub.sidebar",
          "name": "%view.sidebar.name%",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "agentsHub.openPanel",
        "title": "%command.openPanel.title%"
      },
      {
        "command": "agentsHub.reloadWindow",
        "title": "%command.reloadWindow.title%"
      },
      {
        "command": "agentsHub.refreshProviders",
        "title": "%command.refreshProviders.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "agentsHub.openProviderSettings",
        "title": "%command.openProviderSettings.title%",
        "icon": "$(settings-gear)"
      },
      {
        "command": "agentsHub.stopAll",
        "title": "%command.stopAll.title%"
      },
      {
        "command": "agentsHub.explainSelection",
        "title": "%command.explainSelection.title%"
      },
      {
        "command": "agentsHub.reviewFile",
        "title": "%command.reviewFile.title%"
      },
      {
        "command": "agentsHub.generateTests",
        "title": "%command.generateTests.title%"
      },
      {
        "command": "agentsHub.refactorSelection",
        "title": "%command.refactorSelection.title%"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentsHub.refreshProviders",
          "when": "view == agentsHub.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "agentsHub.openProviderSettings",
          "when": "view == agentsHub.sidebar",
          "group": "navigation@2"
        }
      ],
      "editor/context": [
        {
          "command": "agentsHub.explainSelection",
          "when": "editorHasSelection",
          "group": "navigation@10"
        },
        {
          "command": "agentsHub.refactorSelection",
          "when": "editorHasSelection",
          "group": "navigation@11"
        },
        {
          "command": "agentsHub.reviewFile",
          "group": "navigation@12"
        },
        {
          "command": "agentsHub.generateTests",
          "group": "navigation@13"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "agentsHub.defaultProvider": {
          "type": "string",
          "default": "opencode",
          "enum": [
            "claude",
            "gemini",
            "codex",
            "opencode",
            "goose",
            "aider"
          ],
          "description": "%config.defaultProvider.description%"
        },
        "agentsHub.context.includeWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "%config.includeWorkspace.description%"
        },
        "agentsHub.context.includeCurrentFile": {
          "type": "boolean",
          "default": true,
          "description": "%config.includeCurrentFile.description%"
        },
        "agentsHub.context.includeSelection": {
          "type": "boolean",
          "default": true,
          "description": "%config.includeSelection.description%"
        },
        "agentsHub.context.includeDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "%config.includeDiagnostics.description%"
        },
        "agentsHub.context.maxFileChars": {
          "type": "number",
          "default": 12000,
          "minimum": 1000,
          "description": "%config.maxFileChars.description%"
        },
        "agentsHub.context.maxSelectionChars": {
          "type": "number",
          "default": 8000,
          "minimum": 1000,
          "description": "%config.maxSelectionChars.description%"
        },
        "agentsHub.context.maxDiagnostics": {
          "type": "number",
          "default": 12,
          "minimum": 0,
          "description": "%config.maxDiagnostics.description%"
        },
        "agentsHub.home.visibleAgentIds": {
          "type": "array",
          "default": [],
          "description": "%config.home.visibleAgentIds.description%",
          "items": {
            "type": "string",
            "enum": [
              "claude",
              "gemini",
              "codex",
              "opencode",
              "goose",
              "aider"
            ]
          }
        },
        "agentsHub.apiProviders.customProviders": {
          "type": "array",
          "default": [],
          "description": "%config.apiProviders.customProviders.description%",
          "items": {
            "type": "object",
            "required": [
              "id",
              "name"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "baseUrl": {
                "type": "string"
              },
              "apiKeyEnv": {
                "type": "string"
              },
              "model": {
                "type": "string"
              },
              "extraEnv": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "enabled": {
                "type": "boolean",
                "default": true
              }
            }
          }
        },
        "agentsHub.apiProviders.defaultProviderId": {
          "type": "string",
          "default": "",
          "description": "%config.apiProviders.defaultProviderId.description%"
        },
        "agentsHub.apiProviders.agentProviderByCliId": {
          "type": "object",
          "default": {},
          "description": "%config.apiProviders.agentProviderByCliId.description%",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "build:test": "tsc -p tsconfig.json --outDir .test-dist --rootDir src --module commonjs",
    "test": "npm run build:test && node --test tests/*.test.mjs",
    "watch": "node esbuild.mjs --watch",
    "compile": "npm run build",
    "package": "npm run build && npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "js-tiktoken": "^1.0.21"
  }
}
